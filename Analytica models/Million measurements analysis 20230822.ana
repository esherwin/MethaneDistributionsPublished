Model Methane_survey_estim
Title: Methane survey estimation
Author: Evan
Date: Wed, May 20, 2020 4:20 PM
DefaultSize: 48,24
NodeSize: 64,40
DiagState: 2,19,15,566,613,17,10
FontStyle: Arial,15
FileInfo: 0,Model Methane_survey_estim,2,2,0,0,G:\Other computers\My Computer\Documents\Kairos\Operator performance\Million measurements analysis 20230822.ana

Button Save_results
Title: Save results
Description: Saves 10 (or a selected number of) runs of the selected scenario or all scenarios.~
Runs are saved to Saved_results, which are then averaged over all batches into Saved_results_avg, which is exported for use in Sherwin et al. 2023.
NodeLocation: 88,512,1
NodeSize: 56,24
WindState: 2,564,134,720,350
Aliases: Alias Al1975651171
DisplayOutputs: Object Object, Object Module, Module Details1
OnClick: Scenario_batch_count := 1;~
FOR kk := Scenarios_to_run DO BEGIN ~
	Select_scenario := kk;~
	Scenario_unique_ID_s := Scenario_unique_ID_s + 1;~
	{Evaluate(Write_production_sou);~
	Evaluate(Write_midstream_sour);}~
	FOR jj := 1..Number_batches_per_s DO BEGIN	~
		Evaluate(Selected_campaign);~
		Saved_results := IF (Scenario_run_unique_=Scenario_unique_ID_s) AND (Scenario_run_batch=Scenario_batch_count)~
								THEN Key_results~
							ELSE Saved_results;~
		Evaluate(Write_full_CDF_CSV);~
		Evaluate(Write_midstream_CDF_);~
		Scenario_batch_count := Scenario_batch_count + 1~
	END;~
	Scenario_batch_count := 1;~
END

