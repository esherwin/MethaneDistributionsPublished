Index Selected_CM_plumes_i
Title: Selected CM plumes init
Description: All plumes identified by Carbon Mapper in the selected campaign before accounting for the possibility of restricting the campaign region to the Midland or Delaware survey areas of the Fall 2021 Permian campaign.
Definition: INDEX init := IF Include_only_Permian='Yes'~
	THEN Subset((CM_plume_campaign='P - Permian_2019') AND (CM_plumes_with_sourc[CM_plume_field='Basin']=Selected_basin))~
	ELSE IF Selected_campaign='Northeast_PA'~
			 THEN Subset((CM_plume_campaign='B - NorthEast_2021') AND (CM_plumes_with_sourc[CM_plume_field='Basin']=Selected_basin))~
	ELSE IF Selected_basin='Appalachian basin (eastern overthrust area)'~
		THEN Subset((CM_plume_campaign=Selected_campaign)*~
						(CM_plumes_2019_2021[CM_plume_field='plume_lat'] >= Min_PA_latitude))~
	ELSE IF Selected_basin='Uinta basin'~
		THEN Subset((CM_plume_campaign=Selected_campaign)*~
						(CM_plumes_2019_2021[CM_plume_field='plume_lon'] <= Max_UT_longitude)*(CM_plumes_2019_2021[CM_plume_field='Basin']=Selected_basin))~
		ELSE Subset((CM_plume_campaign=Selected_campaign) AND (CM_plumes_with_sourc[CM_plume_field='Basin']=Selected_basin));~
~
IF Include_only_Permian='Yes'~
	THEN CopyIndex(Subset(Sum(init=Permian_2019_plumes1, init)))~
ELSE IF Include_only_Permian='No'~
	THEN CopyIndex(init)~
ELSE Null
NodeLocation: 112,152,1
NodeSize: 88,40
WindState: 2,1080,53,720,350
ValueState: 2,1485,237,416,631,,MIDM

Index Selected_CM_sources3
Title: Selected CM sources init
Description: All sources identified by Carbon Mapper in the selected campaign before accounting for the possibility of restricting the campaign region to the Midland or Delaware survey areas of the Fall 2021 Permian campaign.
Definition: INDEX init := IF Include_only_Permian='Yes'~
	THEN Subset((CM_source_campaign='P - Permian_2019'))~
	ELSE IF Selected_campaign='Northeast_PA'~
			THEN Subset((CM_source_campaign='B - NorthEast_2021'))~
	ELSE IF Selected_basin='Appalachian basin (eastern overthrust area)'~
	THEN Subset((CM_source_campaign=Selected_campaign)*~
					(CM_sources_2019_2021[CM_source_field='source_lat'] >= Min_PA_latitude))~
	ELSE IF Selected_basin='Uinta basin'~
		THEN Subset((CM_source_campaign=Selected_campaign)*~
					(CM_sources_2019_2021[CM_source_field='source_lon'] <= Max_UT_longitude)*(CM_sources_2019_2021[CM_source_field='Basin']=Selected_basin))~
	ELSE Subset((CM_source_campaign=Selected_campaign));~
~
IF Include_only_Permian='Yes'~
	THEN CopyIndex(Subset(Sum(init=Permian_2019_unique_, init)))~
ELSE IF Include_only_Permian='No'~
	THEN CopyIndex(init)~
ELSE Null~
{INDEX init := Subset((CM_source_campaign=Select_CM_campaign) AND CM_OG_prod_source);~
~
IF Include_only_Permian='Yes'~
	THEN CopyIndex(Subset(Sum(init=Permian_2019_unique_, init)))~
ELSE IF Include_only_Permian='No'~
	THEN CopyIndex(init)~
ELSE Null}
