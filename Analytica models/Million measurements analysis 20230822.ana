Variable Rutherford_selected1
Title: Rutherford selected basin production decile by site
Definition: VAR init := (Rutherford_selected6[Rutherford_field2='Gas productivity [mscf/site/day]'] <= Rutherford_selected3[Rutherford_field2='Gas productivity [mscf/site/day]'])*Quantile_to_simulate;~
VAR initZeroToNull := IF init = 0 THEN Null ELSE init;~
Min(initZeroToNull, Quantile_to_simulate)
