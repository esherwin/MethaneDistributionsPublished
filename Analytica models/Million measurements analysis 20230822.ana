Variable Source_level_midst10
Title: Source-level midstream plume emissions for selected CM campaign
Units: kg(CH4)/hr
Description: Source-level midstream emissions for the selected Carbon Mapper campaign.
Definition: IF Source_level_midstr2=Null~
	THEN 0~
ELSE IF Selected_datasource='Kairos Permian' ~
	THEN IF Kairos_source_type_d[Kairos_Permian_plu10=Source_level_midstr2]=Kairos_Permian_asse1~
{Plumes_Yulia_good_in[Plume_fields_Yulia='asset_type_kairos', Plume=Source_level_midstr2]=Kairos_asset_type}~
		THEN Kairos_Permian_mids7[Kairos_Permian_midst=Source_level_midstr2]~
	ELSE Null~
ELSE IF Selected_datasource='Kairos Barnett'~
	THEN IF Kairos_Barnett_sour5[Kairos_Barnett_sour4=Kairos_Barnett_plum3[Kairos_Barnett_plume=Source_level_midstr2, Kairos_Barnett_plum4='emission_source_id'], Kairos_Barnett_sour1='category']=Kairos_Barnett_sour6~
		THEN Kairos_Barnett_mids5[Kairos_Barnett_midst=Source_level_midstr2]~
	ELSE Null~
ELSE IF Selected_datasource='California'~
	THEN IF Duren_O_G_midstream3[Duren_field='Source type (best estimate)', Duren_O_G_midstream7=Source_level_midstr2]=Duren_source_type~
		THEN Duren_O_G_midstream3[Duren_field='Qplume (kg/hr)*', Duren_O_G_midstream7=Source_level_midstr2]~
	ELSE Null~
ELSE IF Selected_datasource='CM'~
	THEN IF All_CM_plumes_quantu[CM_plume_field='source_type', CM_plume=Source_level_midstr2]=CM_detailed_source_t~
		THEN All_CM_plumes_quantu[CM_plume_field='qplume', CM_plume=Source_level_midstr2]~
	ELSE Null~
ELSE Null
