Module Source_level_plumes_
Title: Source-level plumes by MC iteration
Description: For each Monte Carlo iteration, produce a sorted list of aerially measured emission rates to merge with the distribution of simulated emissions.
Author: Evan Sherwin~
Stanford University
Date: Thu, Aug 3, 2023 7:30 AM
NodeLocation: 400,64,1
NodeSize: 64,40
DiagState: 2,37,169,417,453,17,10

Alias Al1186576291
Title: Selected CM OG prod plumes
Definition: 1
NodeLocation: 104,64,1
NodeSize: 80,40
Original: Selected_CM_OG_prod_

Variable Source_level_plume_e
Title: Source-level plume emissions for simulated campaign
Description: Plume emission rates for each Monte Carlo simulation of a single snapshot survey across all surveyed well sites.~
This is analysis is conducted on a source level, rather than on a plume level (which would include all detected plumes in each Monte Carlo simulation, including repeats at a given site).
Definition: IF Source_level_plume_i=Null~
	THEN 0~
ELSE IF Selected_datasource='Kairos Permian' ~
	THEN Kairos_plume_quanti1[Kairos_Permian_plu10=Source_level_plume_i]~
ELSE IF Selected_datasource='Kairos Barnett'~
	THEN Kairos_plume_quanti1[Kairos_Barnett_prod1=Source_level_plume_i]~
ELSE IF Selected_datasource='California'~
	THEN Duren_O_G_production[Duren_field='Qplume (kg/hr)*', Duren_O_G_productio1=Source_level_plume_i]~
ELSE IF Selected_datasource='CM'~
	THEN Selected_CM_OG_prod_[CM_plume_field='qplume', Selected_CM_plume_OG=Source_level_plume_i]~
ELSE Null~

NodeLocation: 104,160,1
NodeSize: 80,40
WindState: 2,477,146,720,350
ValueState: 2,114,159,807,616,,SAMP
ReformVal: [Undefined,Duren_O_G_productio8,Undefined,Undefined,Undefined,1]
Att__TotalsIndex: [Selected_CM_source_O,Kairos_Barnett_emitt,Kairos_Permian_emit1,Run]

Variable Source_level_aerial_
Title: Source-level aerial production emissions sort
Units: kgh
Description: Source-level aerial emission in Monte Carlo simulation, sorted by emission magnitude.
Definition: IgnoreWarnings(~
	IF Selected_datasource='Kairos Permian'~
		THEN Sort(Source_level_plume_e, Kairos_Permian_emit1, descending:True)[@Kairos_Permian_emit1=@Well_site_coverage]~
	ELSE IF Selected_datasource='Kairos Barnett'~
		THEN Sort(Source_level_plume_e, Kairos_Barnett_emitt, descending:True)[@Kairos_Barnett_emitt=@Well_site_coverage]~
	ELSE IF Selected_datasource='California'~
		THEN Sort(Source_level_plume_e, Duren_O_G_productio8, descending:True)[@Duren_O_G_productio8=@Well_site_coverage]~
	ELSE IF Selected_datasource='CM'~
		THEN IF Selected_campaign='CA 2016-2017'~
			THEN Null~
		ELSE Sort(Source_level_plume_e, Selected_CM_source_O, descending:True)[CM_plume_field='qplume',@Selected_CM_source_O=@Well_site_coverage]~
	ELSE Null~
)
NodeLocation: 104,264,1
NodeSize: 80,40
WindState: 2,629,194,720,350
ValueState: 2,285,88,627,603,0,SAMP
ReformVal: [Well_site_coverage,Well_site_coverage,Undefined,Undefined,Undefined,1]
Att__TotalsIndex: [Well_site_coverage,Run]
{!40600|Att_ClusterIndex: Run}

Variable Source_level_aerial1
Title: Source-level aerial emissions consistent index
Description: Aerial emissions in the Monte Carlo simulation with a consistent index.
Definition: IF (Selected_datasource='Kairos Permian') OR (Selected_datasource='Kairos Barnett')~
	THEN IF @Dummy_plume_consiste <= Size(Selected_emission_in)~
		THEN Source_level_aerial_[@Well_site_coverage=@Dummy_plume_consiste]~
	ELSE Null~
ELSE IF Selected_datasource='California'~
	THEN IF @Dummy_plume_consiste <= Size(Duren_O_G_productio1)~
		THEN Source_level_aerial_[@Well_site_coverage=@Dummy_plume_consiste]~
	ELSE Null~
ELSE IF Selected_datasource='CM'~
	THEN IF @Dummy_plume_consiste <= Number_of_aerial_emi~
		THEN Source_level_aerial_[@Well_site_coverage=@Dummy_plume_consiste]~
	ELSE Null
