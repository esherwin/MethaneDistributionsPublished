ValueState: 2,956,212,416,303,,MIDM

Variable Source_level_midstr7
Title: Source-level midstream partial detection probabilities for simulated campaign
Description: Partial detection probabilities for the plumes assigned to each source in each Monte Carlo iteration.
Definition: IF Source_level_midstr2=Null~
	THEN 0~
ELSE IF Selected_datasource='Kairos Permian' ~
	THEN Kairos_Permian_mids5[Plume_fields_from_Pe='partial_detect_correction', Kairos_Permian_midst=Source_level_midstr2]~
ELSE IF Selected_datasource='Kairos Barnett'~
	THEN Kairos_Barnett_mids3[Kairos_Barnett_plum8='partial_detect_correction', Kairos_Barnett_midst=Source_level_midstr2]~
ELSE IF Selected_datasource='California'~
	THEN 1~
ELSE IF Selected_datasource='CM'~
	THEN 1~
ELSE Null~

