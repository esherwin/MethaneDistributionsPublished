ValueState: 2,152,76,536,576,,MIDM

Index Selected_CM_source_b
Title: Selected CM source by campaign
Description: All sources identified by Carbon Mapper in the selected campaign after accounting for the possibility of restricting the campaign region to the Midland or Delaware survey areas of the Fall 2021 Permian campaign.
Definition: IF Selected_campaign='Midland_2019_F2021_bounds'~
	THEN CopyIndex(CM_sources_above_103)~
ELSE IF Selected_campaign='Delaware_2019_F2021_bounds'~
	THEN CopyIndex(CM_sources_below_103)~
ELSE CopyIndex(Selected_CM_sources3)~
{INDEX init := IF Include_only_Permian='Yes'~
	THEN Subset((CM_source_campaign='P - Permian_2019') AND CM_OG_prod_source)~
	ELSE Subset((CM_source_campaign=Select_CM_campaign) AND CM_OG_prod_source);~
~
IF Include_only_Permian='Yes'~
	THEN CopyIndex(Subset(Sum(init=Permian_2019_unique_, init)))~
ELSE IF Include_only_Permian='No'~
	THEN CopyIndex(init)~
ELSE Null~
{INDEX init := Subset((CM_source_campaign=Select_CM_campaign) AND CM_OG_prod_source);~
~
IF Include_only_Permian='Yes'~
	THEN CopyIndex(Subset(Sum(init=Permian_2019_unique_, init)))~
ELSE IF Include_only_Permian='No'~
	THEN CopyIndex(init)~
ELSE Null}}
