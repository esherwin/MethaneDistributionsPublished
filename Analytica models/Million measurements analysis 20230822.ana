NodeSize: 96,40
WindState: 2,116,33,720,350
ValueState: 2,272,113,807,616,0,MEAN
ReformVal: [Duren_O_G_productio8,Kairos_Barnett_emit1,Undefined,Undefined,Undefined,1]
